# Gemini API key (Google AI Studio). Never commit the real value.
GEMINI_API_KEY=

# Cloudflare Tunnel token (filled in on the Droplet only — leave blank locally).
TUNNEL_TOKEN=

# Single CORS origin the API will accept. For local dev set to
# http://localhost:5173; in prod set to https://brianchenhao.com.
ALLOWED_ORIGIN=https://brianchenhao.com
